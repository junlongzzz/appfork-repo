	"category":"development",
	"version":"25.0.2",
	"platform":"linux",
	"url":{
		"graalvm-community-jdk-25.0.2_linux-aarch64_bin.tar.gz":"https://github.com/graalvm/graalvm-ce-builds/releases/download/jdk-25.0.2/graalvm-community-jdk-25.0.2_linux-aarch64_bin.tar.gz",
		"graalvm-community-jdk-25.0.2_linux-x64_bin.tar.gz":"https://github.com/graalvm/graalvm-ce-builds/releases/download/jdk-25.0.2/graalvm-community-jdk-25.0.2_linux-x64_bin.tar.gz"
	},
	"homepage":"https://www.graalvm.org/",
	"script":{
		"args":{
			"url":"github://graalvm/graalvm-ce-builds",
			"regex":"\"tag_name\":\\s*\"jdk-(?<version>[^\"]+)\"",
			"gh":{
				"assets_jsonpath":"$.assets[?(@.name =~ /graalvm-community-jdk-[\\d.]+_linux-(x64|aarch64)_bin\\.tar\\.gz$/i)]"
			}
		},
		"name":"appfork-check-update"
	}
}